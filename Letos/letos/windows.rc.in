#include <windows.h>

ID_ICON ICON DISCARDABLE "@CMAKE_CURRENT_SOURCE_DIR@/../gui/img/letos.ico"
CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "@CMAKE_CURRENT_SOURCE_DIR@/../letos/Letos.exe.manifest"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION     @LETOS_VERSION_MAJOR@,@LETOS_VERSION_MINOR@,@LETOS_VERSION_PATCH@,0
 PRODUCTVERSION  @LETOS_VERSION_MAJOR@,@LETOS_VERSION_MINOR@,@LETOS_VERSION_PATCH@,0
 FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
 FILEOS          VOS_NT_WINDOWS32
 FILETYPE        VFT_APP
 FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "SalSoft"
            VALUE "FileDescription",  "Letos - SQLite database manager"
            VALUE "FileVersion",      "@LETOS_VERSION_STRING@"
            VALUE "InternalName",     "Letos"
            VALUE "LegalCopyright",   "Copyright (C) @YEAR@ letos.org"
            VALUE "OriginalFilename", "Letos.exe"
            VALUE "ProductName",      "Letos"
            VALUE "ProductVersion",   "@LETOS_VERSION_STRING@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
